# Default agent: deepseek
LITERATURE_AGENT=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-pro

# Switch to ChatGPT / OpenAI-compatible Responses API.
# LITERATURE_AGENT=chatgpt
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# Switch to Claude / Anthropic Messages API.
# LITERATURE_AGENT=claude
# ANTHROPIC_API_KEY=sk-ant-your-claude-api-key
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Optional: use a custom JSON config path.
# LITERATURE_AGENT_CONFIG=config/agent_config.json

# Optional: group-level taxonomy generation usually needs more output tokens than single-paper annotation.
# LITERATURE_GROUP_MAX_TOKENS=6000

# Optional: large literature group handling. auto will batch when the group is too large.
# LITERATURE_GROUP_MODE=auto
# LITERATURE_GROUP_BATCH_SIZE=25
# LITERATURE_GROUP_MAX_INPUT_CHARS=60000
# LITERATURE_GROUP_RECORD_ABSTRACT_CHARS=300
# LITERATURE_GROUP_MAX_TAXONOMY_ITEMS=40
# LITERATURE_GROUP_MERGE_SIZE=8

# Optional: force the script to ignore cached AI annotations and ask the model again.
# LITERATURE_REFRESH_AI=1

# Optional: disable model calls and only use cache/neutral fallback.
# LITERATURE_USE_AI=0
