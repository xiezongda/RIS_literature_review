# 推荐直接填写 config/deepseek_v4pro.json。
# 如果你不想把 key 写进配置文件，也可以用环境变量：
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-pro

# Optional: force the script to ignore cached AI annotations and ask the model again.
# LITERATURE_REFRESH_AI=1

# Optional: disable model calls and only use cache/preset/rule fallback.
# LITERATURE_USE_AI=0
